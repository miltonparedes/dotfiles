      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/milton/.superset/hooks/gemini-hook.sh"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/milton/.superset/hooks/gemini-hook.sh"
          }
        ]
      }
    ]
  }
