{{- $byokGatewaySecret := protonPass "pass://Development/ai-gateway/Secret" | trim -}}
{{- $byokGatewayURL := protonPass "pass://Development/ai-gateway/URL" | trim -}}
{{- $byokAnthropicURL := printf "%s/anthropic" $byokGatewayURL -}}
{{- $byokOpenAIURL := printf "%s/openai" $byokGatewayURL -}}
{{- $workersAIShimSecret := protonPass "pass://Development/tools-workers-ai-shim/Secret" | trim -}}
{{- $workersAIShimURL := regexReplaceAll "/+$" (protonPass "pass://Development/tools-workers-ai-shim/URL" | trim) "" -}}
{{- $workersAIShimOpenAIURL := printf "%s/v1" $workersAIShimURL -}}
{{- $gptSubBaseURL := "http://localhost:8317/v1" -}}
{{- if eq .chezmoi.os "linux" -}}
{{- $gptSubBaseURL = "http://127.0.0.1:8317/v1" -}}
{{- end -}}
{{- $gptSubSecret := protonPass "pass://Development/gpt-proxy/Secret" | trim -}}
{
  "cloudSessionSync": true,
  "diffMode": "github",
  "ideExtensionPromptedAt": {},
  "ideActivationNudgedForVersion": {},
  "enableCompletionBell": false,
  "completionSound": "fx-ok01",
  "awaitingInputSound": "fx-ack01",
  "soundFocusMode": "always",
  "commandAllowlist": [
    "ls",
    "pwd",
    "dir"
  ],
  "commandDenylist": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf .",
    "rm -rf ~",
    "rm -rf ~/*",
    "rm -rf $HOME",
    "rm -r /",
    "rm -r /*",
    "rm -r ~",
    "rm -r ~/*",
    "mkfs",
    "mkfs.ext4",
    "mkfs.ext3",
    "mkfs.vfat",
    "mkfs.ntfs",
    "dd if=/dev/zero of=/dev",
    "dd of=/dev",
    "shutdown",
    "reboot",
    "halt",
    "poweroff",
    "init 0",
    "init 6",
    ":(){ :|: & };:",
    ":() { :|:& };:",
    "chmod -R 777 /",
    "chmod -R 000 /",
    "chown -R",
    "format",
    "powershell Remove-Item -Recurse -Force"
  ],
  "enableCustomDroids": true,
  "enableHooks": true,
  "includeCoAuthoredByDroid": false,
  "enableDroidShield": true,
  "enableReadinessReport": false,
  "todoDisplayMode": "pinned",
  "allowBackgroundProcesses": true,
  "completionSoundFocusMode": "always",
  "enableSkills": false,
  "sessionDefaultSettings": {
    "model": "custom:GPT-5.5-sub-3",
    "reasoningEffort": "high",
    "autonomyMode": "auto-medium",
    "interactionMode": "auto",
    "autonomyLevel": "medium",
    "specModeModel": "custom:Opus-4.8-0",
    "specModeReasoningEffort": "xhigh"
  },
  "dismissedNewModels": [
    "claude-opus-4-8",
    "kimi-k2.7-code"
  ],
  "customModels": [
    {
      "model": "claude-opus-4-8",
      "id": "custom:Opus-4.8-0",
      "index": 0,
      "baseUrl": "{{ $byokAnthropicURL }}",
      "apiKey": "{{ $byokGatewaySecret }}",
      "extraHeaders": {
        "cf-aig-authorization": "Bearer {{ $byokGatewaySecret }}"
      },
      "displayName": "Opus 4.8 BYOK",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "gpt-5.5",
      "id": "custom:GPT-5.5-api-2",
      "index": 2,
      "baseUrl": "{{ $byokOpenAIURL }}",
      "apiKey": "{{ $byokGatewaySecret }}",
      "extraHeaders": {
        "cf-aig-authorization": "Bearer {{ $byokGatewaySecret }}"
      },
      "displayName": "GPT 5.5 BYOK",
      "maxContextLimit": 1050000,
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "model": "gpt-5.5",
      "id": "custom:GPT-5.5-sub-3",
      "index": 3,
      "baseUrl": "{{ $gptSubBaseURL }}",
      "apiKey": "{{ $gptSubSecret }}",
      "displayName": "GPT 5.5 Sub",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "model": "claude-sonnet-5",
      "id": "custom:Sonnet-5-4",
      "index": 4,
      "baseUrl": "{{ $byokAnthropicURL }}",
      "apiKey": "{{ $byokGatewaySecret }}",
      "extraHeaders": {
        "cf-aig-authorization": "Bearer {{ $byokGatewaySecret }}"
      },
      "displayName": "Sonnet 5 BYOK",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "claude-fable-5",
      "id": "custom:Fable-5-6",
      "index": 6,
      "baseUrl": "{{ $byokAnthropicURL }}",
      "apiKey": "{{ $byokGatewaySecret }}",
      "extraHeaders": {
        "cf-aig-authorization": "Bearer {{ $byokGatewaySecret }}"
      },
      "displayName": "Fable 5 BYOK",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "@cf/zai-org/glm-5.2",
      "id": "custom:GLM-5.2-workers-5",
      "index": 5,
      "baseUrl": "{{ $workersAIShimOpenAIURL }}",
      "apiKey": "{{ $workersAIShimSecret }}",
      "displayName": "GLM 5.2 Workers AI",
      "maxContextLimit": 262144,
      "maxOutputTokens": 32768,
      "noImageSupport": true,
      "provider": "openai"
    },
    {
      "model": "gpt-5.5-pro",
      "id": "custom:GPT-5.5-pro-8",
      "index": 8,
      "baseUrl": "{{ $gptSubBaseURL }}",
      "apiKey": "{{ $gptSubSecret }}",
      "displayName": "GPT 5.5 Pro",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    }
  ],
  "logoAnimation": "off",
  "showTokenUsageIndicator": true,
  "enabledPlugins": {
    "core@factory-plugins": true,
    "droid-evolved@factory-plugins": true,
    "droid-control@factory-plugins": true,
    "autoresearch@factory-plugins": true
  },
  "hasSeenMissionOnboarding": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "'/Users/milton/.config/kitmux/hooks/agent-event' --agent droid --event notification --stdin-json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "'/Users/milton/.config/kitmux/hooks/agent-event' --agent droid --event post-tool-use --stdin-json",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "'/Users/milton/.config/kitmux/hooks/agent-event' --agent droid --event pre-tool-use --stdin-json",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
