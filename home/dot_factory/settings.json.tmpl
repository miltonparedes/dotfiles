{{- $aiGatewayBaseURL := protonPass "pass://Development/ai-gateway/URL" | trim -}}
{{- $aiGatewaySecret := protonPass "pass://Development/ai-gateway/Secret" | trim -}}
{{- $anthropicGatewayURL := printf "%s/anthropic" $aiGatewayBaseURL -}}
{{- $openAIGatewayURL := printf "%s/openai" $aiGatewayBaseURL -}}
{{- $localHost := "localhost" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $localHost = .remote_host -}}
{{- end -}}
{{- $localAlloyBaseURL := printf "http://%s:8081/bedrock" $localHost -}}
{{- $localAlloySecret := "local-alloy" -}}
{{- $gptSubBaseURL := printf "http://%s:8317/v1" $localHost -}}
{{- $gptSubSecret := protonPass "pass://Development/gpt-proxy/Secret" | trim -}}
{
  "cloudSessionSync": true,
  "diffMode": "github",
  "ideExtensionPromptedAt": {},
  "ideActivationNudgedForVersion": {},
  "enableCompletionBell": false,
  "completionSound": "fx-ok01",
  "awaitingInputSound": "fx-ack01",
  "soundFocusMode": "always",
  "commandAllowlist": [
    "ls",
    "pwd",
    "dir"
  ],
  "commandDenylist": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf .",
    "rm -rf ~",
    "rm -rf ~/*",
    "rm -rf $HOME",
    "rm -r /",
    "rm -r /*",
    "rm -r ~",
    "rm -r ~/*",
    "mkfs",
    "mkfs.ext4",
    "mkfs.ext3",
    "mkfs.vfat",
    "mkfs.ntfs",
    "dd if=/dev/zero of=/dev",
    "dd of=/dev",
    "shutdown",
    "reboot",
    "halt",
    "poweroff",
    "init 0",
    "init 6",
    ":(){ :|: & };:",
    ":() { :|:& };:",
    "chmod -R 777 /",
    "chmod -R 000 /",
    "chown -R",
    "format",
    "powershell Remove-Item -Recurse -Force"
  ],
  "enableCustomDroids": true,
  "enableHooks": false,
  "includeCoAuthoredByDroid": false,
  "enableDroidShield": true,
  "enableReadinessReport": false,
  "todoDisplayMode": "pinned",
  "allowBackgroundProcesses": true,
  "completionSoundFocusMode": "always",
  "enableSkills": false,
