{{- $aiGatewayBaseURL := protonPass "pass://Development/ai-gateway/URL" | trim -}}
{{- $aiGatewaySecret := protonPass "pass://Development/ai-gateway/Secret" | trim -}}
{{- $aiGatewayAccessClientID := protonPass "pass://Metall/Cloudflare AI Gateway/API Key" | trim -}}
{{- $aiGatewayAccessClientSecret := protonPass "pass://Metall/Cloudflare AI Gateway/Secret" | trim -}}
{{- $anthropicGatewayURL := printf "%s/anthropic" $aiGatewayBaseURL -}}
{{- $openAIGatewayURL := printf "%s/openai" $aiGatewayBaseURL -}}
{{- $gptSubBaseURL := "http://localhost:8317/v1" -}}
{{- if eq .chezmoi.os "linux" -}}
{{- $gptSubBaseURL = "http://127.0.0.1:8317/v1" -}}
{{- end -}}
{{- $gptSubSecret := protonPass "pass://Development/gpt-proxy/Secret" | trim -}}
{
  "cloudSessionSync": true,
  "diffMode": "github",
  "ideExtensionPromptedAt": {},
  "ideActivationNudgedForVersion": {},
  "enableCompletionBell": false,
  "completionSound": "fx-ok01",
  "awaitingInputSound": "fx-ack01",
  "soundFocusMode": "always",
  "commandAllowlist": [
    "ls",
    "pwd",
    "dir"
  ],
  "commandDenylist": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf .",
    "rm -rf ~",
    "rm -rf ~/*",
    "rm -rf $HOME",
    "rm -r /",
    "rm -r /*",
    "rm -r ~",
    "rm -r ~/*",
    "mkfs",
    "mkfs.ext4",
    "mkfs.ext3",
    "mkfs.vfat",
    "mkfs.ntfs",
    "dd if=/dev/zero of=/dev",
    "dd of=/dev",
    "shutdown",
    "reboot",
    "halt",
    "poweroff",
    "init 0",
    "init 6",
    ":(){ :|: & };:",
    ":() { :|:& };:",
    "chmod -R 777 /",
    "chmod -R 000 /",
    "chown -R",
    "powershell Remove-Item -Recurse -Force"
  ],
  "enableCustomDroids": true,
  "enableHooks": false,
  "includeCoAuthoredByDroid": false,
  "enableDroidShield": true,
  "enableReadinessReport": false,
  "todoDisplayMode": "pinned",
  "allowBackgroundProcesses": true,
  "completionSoundFocusMode": "always",
  "enableSkills": false,
  "sessionDefaultSettings": {
    "model": "custom:GPT-5.5-sub-3",
    "reasoningEffort": "high",
    "autonomyMode": "auto-medium",
    "interactionMode": "auto",
    "autonomyLevel": "medium",
    "specModeModel": "custom:Opus-4.8-bedrock-5",
    "specModeReasoningEffort": "xhigh"
  },
  "customModels": [
    {
      "model": "claude-opus-4-8",
      "id": "custom:Opus-4.8-0",
      "index": 0,
      "baseUrl": "{{ $anthropicGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "extraHeaders": {
        "CF-Access-Client-Id": "{{ $aiGatewayAccessClientID }}",
        "CF-Access-Client-Secret": "{{ $aiGatewayAccessClientSecret }}"
      },
      "displayName": "Opus 4.8",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "gpt-5.5",
      "id": "custom:GPT-5.5-api-2",
      "index": 2,
      "baseUrl": "{{ $openAIGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "extraHeaders": {
        "CF-Access-Client-Id": "{{ $aiGatewayAccessClientID }}",
        "CF-Access-Client-Secret": "{{ $aiGatewayAccessClientSecret }}"
      },
      "displayName": "GPT 5.5 API",
      "maxContextLimit": 1050000,
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "model": "gpt-5.5",
      "id": "custom:GPT-5.5-sub-3",
      "index": 3,
      "baseUrl": "{{ $gptSubBaseURL }}",
      "apiKey": "{{ $gptSubSecret }}",
      "displayName": "GPT 5.5 Sub",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "model": "claude-sonnet-4-6",
      "id": "custom:Sonnet-4.6-4",
      "index": 4,
      "baseUrl": "{{ $anthropicGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "extraHeaders": {
        "CF-Access-Client-Id": "{{ $aiGatewayAccessClientID }}",
        "CF-Access-Client-Secret": "{{ $aiGatewayAccessClientSecret }}"
      },
      "displayName": "Sonnet 4.6",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 64000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "us.anthropic.claude-opus-4-8",
      "id": "custom:Opus-4.8-bedrock-5",
      "index": 5,
      "displayName": "Opus 4.8 Bedrock",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 64000,
      "noImageSupport": false,
      "provider": "anthropic",
      "bedrock": {
        "awsRegion": "us-east-1"
      }
    },
    {
      "model": "claude-fable-5",
      "id": "custom:Fable-5-6",
      "index": 6,
      "baseUrl": "{{ $anthropicGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "extraHeaders": {
        "CF-Access-Client-Id": "{{ $aiGatewayAccessClientID }}",
        "CF-Access-Client-Secret": "{{ $aiGatewayAccessClientSecret }}"
      },
      "displayName": "Fable 5",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 128000,
      "extraArgs": {
        "thinking": {
          "type": "adaptive",
          "display": "summarized"
        }
      },
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "global.anthropic.claude-fable-5",
      "id": "custom:Fable-5-bedrock-7",
      "index": 7,
      "displayName": "Fable 5 Bedrock",
      "maxContextLimit": 1000000,
      "maxOutputTokens": 128000,
      "bedrock": {
        "awsRegion": "us-east-1"
      },
      "extraArgs": {
        "thinking": {
          "type": "adaptive",
          "display": "summarized"
        }
      },
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "gpt-5.5-pro",
      "id": "custom:GPT-5.5-pro-8",
      "index": 8,
      "baseUrl": "{{ $gptSubBaseURL }}",
      "apiKey": "{{ $gptSubSecret }}",
      "displayName": "GPT 5.5 Pro",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    }
  ],
  "logoAnimation": "off",
  "showTokenUsageIndicator": true,
  "enabledPlugins": {
    "core@factory-plugins": true,
    "droid-evolved@factory-plugins": true,
    "droid-control@factory-plugins": true,
    "autoresearch@factory-plugins": true
  },
  "hasSeenMissionOnboarding": true,
  "nerdFont": true,
  "reauthBannerShownTui": true,
  "modelFavorites": [
    "custom:GPT-5.5-sub-3",
    "custom:Opus-4.8-bedrock-5",
    "custom:Opus-4.8-0",
    "custom:GPT-5.5-api-2",
    "custom:GPT-5.5-pro-8"
  ]
}
