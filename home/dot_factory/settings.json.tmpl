          {
            "command": "'/Users/milton/.config/kitmux/hooks/agent-event' --agent droid --event session-end --stdin-json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
