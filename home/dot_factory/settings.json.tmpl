{{- $aiGatewayBaseURL := protonPass "pass://Development/ai-gateway/URL" | trim -}}
{{- $aiGatewaySecret := protonPass "pass://Development/ai-gateway/Secret" | trim -}}
{{- $anthropicGatewayURL := printf "%s/anthropic" $aiGatewayBaseURL -}}
{{- $openAIGatewayURL := printf "%s/openai" $aiGatewayBaseURL -}}
{{- $localHost := "localhost" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $localHost = .remote_host -}}
{{- end -}}
{{- $localAlloyBaseURL := printf "http://%s:8081/bedrock" $localHost -}}
{{- $localAlloySecret := "local-alloy" -}}
{{- $gptSubBaseURL := printf "http://%s:8317/v1" $localHost -}}
{{- $gptSubSecret := protonPass "pass://Development/gpt-proxy/Secret" | trim -}}
{
  "cloudSessionSync": true,
  "diffMode": "github",
  "ideExtensionPromptedAt": {},
  "ideActivationNudgedForVersion": {},
  "enableCompletionBell": false,
  "completionSound": "fx-ok01",
  "awaitingInputSound": "fx-ack01",
  "soundFocusMode": "always",
  "commandAllowlist": [
    "ls",
    "pwd",
    "dir"
  ],
  "commandDenylist": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf .",
    "rm -rf ~",
    "rm -rf ~/*",
    "rm -rf $HOME",
    "rm -r /",
    "rm -r /*",
    "rm -r ~",
    "rm -r ~/*",
    "mkfs",
    "mkfs.ext4",
    "mkfs.ext3",
    "mkfs.vfat",
    "mkfs.ntfs",
    "dd if=/dev/zero of=/dev",
    "dd of=/dev",
    "shutdown",
    "reboot",
    "halt",
    "poweroff",
    "init 0",
    "init 6",
    ":(){ :|: & };:",
    ":() { :|:& };:",
    "chmod -R 777 /",
    "chmod -R 000 /",
    "chown -R",
    "format",
    "powershell Remove-Item -Recurse -Force"
  ],
  "enableCustomDroids": true,
  "enableHooks": false,
  "includeCoAuthoredByDroid": false,
  "enableDroidShield": true,
  "enableReadinessReport": false,
  "todoDisplayMode": "pinned",
  "allowBackgroundProcesses": true,
  "completionSoundFocusMode": "always",
  "enableSkills": false,
  "sessionDefaultSettings": {
    "model": "custom:GPT-5.5-sub-3",
    "reasoningEffort": "high",
    "autonomyMode": "auto-low",
    "interactionMode": "auto",
    "autonomyLevel": "low"
  },
  "customModels": [
    {
      "model": "claude-opus-4-7",
      "id": "custom:Opus-4.7-0",
      "index": 0,
      "baseUrl": "{{ $anthropicGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "displayName": "Opus 4.7",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "global.anthropic.claude-opus-4-7",
      "id": "custom:Opus-4.7-local-bedrock-1",
      "index": 1,
      "baseUrl": "{{ $localAlloyBaseURL }}",
      "apiKey": "{{ $localAlloySecret }}",
      "displayName": "Opus 4.7 local bedrock",
      "maxOutputTokens": 64000,
      "noImageSupport": false,
      "provider": "anthropic"
    },
    {
      "model": "gpt-5.5",
      "id": "custom:GPT-5.5-api-2",
      "index": 2,
      "baseUrl": "{{ $openAIGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "displayName": "GPT 5.5 API",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "model": "gpt-5.5",
      "id": "custom:GPT-5.5-sub-3",
      "index": 3,
      "baseUrl": "{{ $gptSubBaseURL }}",
      "apiKey": "{{ $gptSubSecret }}",
      "displayName": "GPT 5.5 Sub",
      "maxOutputTokens": 128000,
      "noImageSupport": false,
      "provider": "openai"
    },
    {
      "model": "claude-sonnet-4-6",
      "id": "custom:Sonnet-4.6-4",
      "index": 4,
      "baseUrl": "{{ $anthropicGatewayURL }}",
      "apiKey": "{{ $aiGatewaySecret }}",
      "displayName": "Sonnet 4.6",
      "maxOutputTokens": 64000,
      "noImageSupport": false,
      "provider": "anthropic"
    }
  ],
  "logoAnimation": "off",
  "showTokenUsageIndicator": true
}
