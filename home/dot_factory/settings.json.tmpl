            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "'/Users/milton/.config/kitmux/hooks/agent-event' --agent droid --event stop --stdin-json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "'/Users/milton/.config/kitmux/hooks/agent-event' --agent droid --event user-prompt-submit --stdin-json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "nerdFont": false,
  "reauthBannerShownTui": true,
  "modelFavorites": [
    "custom:GPT-5.5-sub-3",
    "custom:GLM-5.2-workers-5",
    "custom:Opus-4.8-0",
    "custom:Fable-5-6",
    "custom:Sonnet-5-4",
    "custom:GPT-5.5-api-2",
    "custom:GPT-5.5-pro-8"
  ],
  "windowZoomLevel": 0,
  "toolResultDisplay": "compact"
}
